{
  "name": "pyplone-language",
  "displayName": "PyPlone Language Support",
  "description": "Syntax highlighting and language server for PyPlone (.pylo)",
  "version": "0.0.1",
  "publisher": "pyplone",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:pyplone"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "pyplone",
        "aliases": [
          "PyPlone",
          "pyplone"
        ],
        "extensions": [
          ".pylo"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pyplone",
        "scopeName": "source.pyplone",
        "path": "./syntaxes/pyplone.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "pyplone",
        "path": "./snippets/pyplone.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}