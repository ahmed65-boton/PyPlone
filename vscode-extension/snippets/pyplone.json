{
  "Seed Function": {
    "prefix": "seed",
    "body": [
      "seed ${1:name}(${2}):",
      "    ${3:rest}"
    ],
    "description": "Create a PyPlone function"
  },
  "Grove Class": {
    "prefix": "grove",
    "body": [
      "grove ${1:Tree}:",
      "    seed open(self):",
      "        ${2:rest}"
    ],
    "description": "Create a PyPlone class"
  },
  "Branch Block": {
    "prefix": "branch",
    "body": [
      "branch ${1:condition}:",
      "    ${2:rest}"
    ],
    "description": "If block in PyPlone"
  },
  "Branch Otherwise": {
    "prefix": "branchelse",
    "body": [
      "branch ${1:condition}:",
      "    ${2:rest}",
      "otherwise:",
      "    ${3:rest}"
    ],
    "description": "If else block in PyPlone"
  },
  "Import Get": {
    "prefix": "get",
    "body": [
      "get ${1:module}"
    ],
    "description": "Import a module"
  },
  "From Take Get": {
    "prefix": "take",
    "body": [
      "take ${1:name} from ${2:module}"
    ],
    "description": "Import a name from a module"
  },
  "Bloom GUI": {
    "prefix": "bloomgui",
    "body": [
      "bloom gui \"${1:Leaf App}\":",
      "    size ${2:320}, ${3:200}",
      "    tint \"${4:#dff5e3}\"",
      "",
      "    text \"${5:Hello from PyLo!}\"",
      "    leaf \"${6:Press}\":",
      "        on tap:",
      "            popup \"${7:PyLo}\", \"${8:Button pressed}\""
    ],
    "description": "Simple no-console GUI block"
  },
  "Leaf Button": {
    "prefix": "leaf",
    "body": [
      "leaf \"${1:Tap Me}\":",
      "    on tap:",
      "        ${2:popup \"PyLo\", \"Tapped\"}"
    ],
    "description": "Button block"
  },
  "Echo": {
    "prefix": "echo",
    "body": [
      "echo(${1:value})"
    ],
    "description": "Print text"
  },
  "Let": {
    "prefix": "let",
    "body": [
      "let ${1:name} = ${2:value}"
    ],
    "description": "Assignment"
  }
}
