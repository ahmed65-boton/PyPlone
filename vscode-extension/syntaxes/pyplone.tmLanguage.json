{
  "name": "PyPlone",
  "scopeName": "source.pyplone",
  "fileTypes": ["pylo"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#gui-blocks" },
    { "include": "#definitions" },
    { "include": "#imports" },
    { "include": "#flow" },
    { "include": "#constants" },
    { "include": "#builtins" },
    { "include": "#numbers" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.number-sign.pyplone", "match": "#.*$" },
        { "name": "comment.block.pyplone", "begin": "###", "end": "###" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.pyplone", "begin": "\"", "end": "\"", "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.pyplone" }] },
        { "name": "string.quoted.single.pyplone", "begin": "'", "end": "'", "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.pyplone" }] }
      ]
    },
    "gui-blocks": {
      "patterns": [
        { "name": "keyword.control.gui.pyplone", "match": "\\b(bloom\\s+gui|leaf|field|text|popup|on\\s+tap|size|tint|ink|pad)\\b" }
      ]
    },
    "definitions": {
      "patterns": [
        {
          "match": "\\b(seed)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.function.pyplone" },
            "2": { "name": "entity.name.function.pyplone" }
          }
        },
        {
          "match": "\\b(grove)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.class.pyplone" },
            "2": { "name": "entity.name.type.class.pyplone" }
          }
        }
      ]
    },
    "imports": {
      "patterns": [
        { "name": "keyword.control.import.pyplone", "match": "\\b(get|take|from|as)\\b" }
      ]
    },
    "flow": {
      "patterns": [
        { "name": "keyword.control.flow.pyplone", "match": "\\b(branch|otherwise\\s+if|otherwise|rest|stop|skip|give|await|try|except|finally|raise|with|in|is|not|and|or)\\b" },
        { "name": "storage.modifier.assignment.pyplone", "match": "\\b(let)\\b" }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.pyplone", "match": "\\b(yes|no|nothing|self)\\b" }
      ]
    },
    "builtins": {
      "patterns": [
        { "name": "support.function.builtin.pyplone", "match": "\\b(echo|range|len|open|int|float|str|list|dict|set|tuple|input|type|abs|min|max|sum|round|enumerate|zip)\\b" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.pyplone", "match": "\\b[0-9]+\\.[0-9]+\\b" },
        { "name": "constant.numeric.integer.pyplone", "match": "\\b[0-9]+\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.assignment.pyplone", "match": "=|:=|\\+=|-=|\\*=|/=|%=|->" },
        { "name": "keyword.operator.arithmetic.pyplone", "match": "\\+|\\-|\\*|/|%|\\*\\*|//" },
        { "name": "keyword.operator.comparison.pyplone", "match": "==|!=|<=|>=|<|>" }
      ]
    }
  }
}
